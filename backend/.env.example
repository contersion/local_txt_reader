APP_NAME=TXT Reader API
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:24412,http://127.0.0.1:24412
DATA_DIR=data
UPLOAD_DIR=uploads
DATABASE_URL=
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_TXT_ENCODING=utf-8
ONLINE_REQUEST_TIMEOUT_SECONDS=15
ONLINE_RESPONSE_SIZE_LIMIT_BYTES=2097152
ONLINE_DEFAULT_USER_AGENT=TXT-Reader/Phase1
ONLINE_FOLLOW_REDIRECTS=true
